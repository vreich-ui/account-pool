# Copy to .env and fill in. Names only live here — never real secret values.
# The vault master key is referenced by the NAME of the env var below, and the
# value is read from that env var at runtime (never stored in the metadata DB).

# ---- Core ----
ACCOUNT_POOL_ENVIRONMENT=dev
# Safety default: when true, no adapter performs a real network write.
ACCOUNT_POOL_DRY_RUN=true
ACCOUNT_POOL_LOG_LEVEL=INFO

# ---- Storage ----
ACCOUNT_POOL_DATABASE_URL=sqlite:///./account_pool.db
ACCOUNT_POOL_VAULT_PATH=./account_pool_vault.db

# ---- Vault master key ----
# Name of the env var that holds the Fernet master key (base64, 32 bytes urlsafe).
ACCOUNT_POOL_VAULT_MASTER_KEY_ENV=ACCOUNT_POOL_MASTER_KEY
# The actual key value (generate with: python -m account_pool.vault.keyref --generate)
# ACCOUNT_POOL_MASTER_KEY=

# ---- Adapters ----
# Comma-separated platforms to back with real (network) adapters instead of the FakeAdapter.
# Requires the matching extra installed (e.g. pip install -e '.[reddit]'). dry_run still gates writes.
# ACCOUNT_POOL_REAL_ADAPTERS=reddit

# ---- Policy defaults ----
ACCOUNT_POOL_DEFAULT_LOCK_TTL_SECONDS=900
# Third-party comments/replies require approval by default (hybrid autonomy).
ACCOUNT_POOL_DEFAULT_REQUIRE_APPROVAL=true
# Open approvals older than this (seconds) are stale and cannot be approved (default 24h).
ACCOUNT_POOL_APPROVAL_TTL_SECONDS=86400

# ---- Admin REST surface (account-pool-admin) ----
ACCOUNT_POOL_ADMIN_HOST=127.0.0.1
ACCOUNT_POOL_ADMIN_PORT=8849
# Name of the env var holding the admin bearer token (unset = open in dev, denied in prod).
ACCOUNT_POOL_ADMIN_BEARER_ENV=ACCOUNT_POOL_ADMIN_BEARER
# ACCOUNT_POOL_ADMIN_BEARER=

# ---- MCP transport ----
# stdio | http
ACCOUNT_POOL_MCP_TRANSPORT=stdio
ACCOUNT_POOL_MCP_HOST=127.0.0.1
ACCOUNT_POOL_MCP_PORT=8848
# For http transport, name of the env var holding the bearer token (CMS-Agent pattern).
ACCOUNT_POOL_MCP_BEARER_ENV=ACCOUNT_POOL_MCP_BEARER

# ---- Platform credentials (per-account, entered via account_connect; examples only) ----
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=account-pool/0.1 by u/your_owned_account
